PORT=3001
thWEB_URL=http://localhost:3000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=dream_league_api
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis
# RSA key pair for JWT signing (RS256)
# Generate with: node scripts/generate-keypair.ts
# Provide as PEM strings or file paths
# JWT_PRIVATE_KEY=<pem-string>
# JWT_PUBLIC_KEY=<pem-string>
# JWT_PRIVATE_KEY_PATH=./jwt-private.pem
# JWT_PUBLIC_KEY_PATH=./jwt-public.pem
# In development, keys are auto-generated if not provided
JWT_EXPIRY_IN_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
# Set to true only for initial setup; false restricts registration to league members
ALLOW_NON_MEMBER_REGISTRATION=false
