{
  "name": "dream-league-api",
  "version": "0.0.0",
  "description": "Dream League backend service",
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node src/index.ts",
    "dev": "NODE_ENV=development node --env-file-if-exists=.env --watch --watch-path=./src src/index.ts",
    "dev:debug": "NODE_ENV=development node --env-file-if-exists=.env --watch --watch-path=./src --inspect src/index.ts",
    "local": "npm run services:up && npm run migrate && npm run dev",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "docker:build": "docker compose --profile app build",
    "docker:dev": "docker compose --profile app up",
    "migrate": "sequelize db:migrate",
    "typecheck": "tsc",
    "test": "npm run typecheck && cross-env TZ=UTC vitest run --coverage",
    "test:unit": "cross-env TZ=UTC vitest run --coverage --project unit",
    "test:integration": "cross-env TZ=UTC vitest run --coverage --project integration",
    "test:watch": "cross-env TZ=UTC vitest",
    "test:debug": "cross-env TZ=UTC vitest --inspect --no-file-parallelism",
    "test:lint": "eslint",
    "test:lint:fix": "eslint --fix"
  },
  "author": "John Watson",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "10.0.0",
    "@hapi/hapi": "21.4.9",
    "@hapi/inert": "7.1.1",
    "@hapi/vision": "7.0.0",
    "@hapi/wreck": "18.1.2",
    "bcrypt": "6.0.0",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "hapi-auth-jwt2": "10.7.0",
    "hapi-pino": "10.1.0",
    "joi": "18.2.1",
    "log-timestamp": "0.3.0",
    "nodemailer": "9.0.1",
    "nunjucks": "3.2.4",
    "pg": "8.7.3",
    "pg-hstore": "2.3.4",
    "redis": "4.6.10",
    "sequelize": "6.37.8",
    "sequelize-cli": "6.4.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.3",
    "@types/bcrypt": "6.0.0",
    "@types/convict": "6.1.6",
    "@types/convict-format-with-validator": "6.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "26.0.1",
    "@types/nodemailer": "8.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "cross-env": "10.1.0",
    "eslint": "9.7.0",
    "neostandard": "0.11.1",
    "testcontainers": "12.0.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
